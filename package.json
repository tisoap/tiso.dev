{
	"name": "tiso.dev",
	"version": "1.0.0",
	"description": "tiso.dev",
	"keywords": [],
	"license": "MIT",
	"author": "Tiso Alvarez Puccinelli",
	"scripts": {
		"analyze": "ANALYZE=true yarn build && serve .next/analyze",
		"build": "next build",
		"check": "yarn typecheck && yarn spellcheck && yarn prettier && yarn eslint",
		"dev": "next",
		"eslint": "eslint --report-unused-disable-directives --fix --ext .js,.ts,.jsx,.tsx .",
		"generate-theme-typings": "chakra-cli tokens --strict-component-types ./providers/ThemeProvider/theme.ts",
		"prettier": "prettier --write './**/*.{js,jsx,ts,tsx,css,md,mdx,json}' --config ./.prettierrc",
		"spellcheck": "cspell --no-progress '**/*.{js,jsx,ts,tsx,json,css,scss,md,mdx}'",
		"start": "next start",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@chakra-ui/react": "1.8.3",
		"@emotion/react": "11.7.1",
		"@emotion/styled": "11.6.0",
		"@mdx-js/loader": "2.0.0",
		"@mdx-js/react": "2.0.0",
		"@next/mdx": "12.0.10",
		"date-fns": "2.28.0",
		"framer-motion": "6.2.4",
		"gray-matter": "4.0.3",
		"is-mobile": "3.0.0",
		"next": "12.0.10",
		"next-mdx-remote": "3.0.8",
		"prism-themes": "1.9.0",
		"prismjs": "1.26.0",
		"react": "17.0.2",
		"react-dom": "17.0.2",
		"react-icons": "4.3.1",
		"reading-time": "1.5.0",
		"rehype": "12.0.1",
		"rehype-prism-plus": "1.3.1",
		"sass": "1.49.7"
	},
	"devDependencies": {
		"@chakra-ui/cli": "1.8.1",
		"@next/bundle-analyzer": "12.0.10",
		"@next/eslint-plugin-next": "12.0.10",
		"@types/mdx-js__react": "1.5.5",
		"@types/react": "17.0.39",
		"@types/react-dom": "17.0.11",
		"@typescript-eslint/eslint-plugin": "5.10.2",
		"@typescript-eslint/parser": "5.10.2",
		"cspell": "5.18.3",
		"eslint": "8.8.0",
		"eslint-config-next": "12.0.10",
		"eslint-config-prettier": "8.3.0",
		"eslint-plugin-import": "2.25.4",
		"eslint-plugin-jsx-a11y": "6.5.1",
		"eslint-plugin-prettier": "4.0.0",
		"eslint-plugin-react": "7.28.0",
		"eslint-plugin-react-hooks": "4.3.0",
		"prettier": "2.5.1",
		"serve": "13.0.2",
		"typescript": "4.5.5"
	},
	"engines": {
		"node": ">=14"
	},
	"packageManager": "yarn@3.1.1"
}
